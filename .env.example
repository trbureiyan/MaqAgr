# Base de API. Dejar vacío para usar rutas relativas (/api/*)
# y apoyarse en el proxy de Vite o en routes de Vercel.
VITE_API_URL=

# Destino real del backend para desarrollo local con Vite.
VITE_DEV_API_PROXY_TARGET=http://localhost:4000

# Puerto de Vite en desarrollo.
VITE_PORT=5173

# Feature flags Mock/Remote por dominio.
VITE_ENABLE_REMOTE_TRACTOR_API=false
VITE_ENABLE_REMOTE_IMPLEMENT_API=false
VITE_ENABLE_REMOTE_NOTIFICATION_API=false
VITE_ENABLE_REMOTE_TERRAIN_API=false
VITE_ENABLE_REMOTE_CALCULATION_API=false
VITE_ENABLE_REMOTE_AUTH_API=false
